{{!
    @template block_mathsyntaxhelp/admin/setting/syntaxtranslation

    Displays a syntaxtranslation admin setting instance.

    Example context (json):
    {
        "name": "s_block_mathsyntaxhelp_foo",
        "entries": [
            {
                "id": 1,
                "out": "\\(\\log_e(y)\\): \)",
                "in": "ln(y)"
            },
            {
                "id": 2,
                "out": "\\(\\sqrt{x}\\)",
                "in": "sqrt(x)"
            },
            {
                "id": 3,
                "out": "",
                "in": ""
            }
        ]
    }
}}

<div class="form-syntaxtranslations defaultsnext">
    <table class="table d-inline">
        <thead>
            <tr>
                <th scope="col" class="border-top-0">{{#str}} math_expression, block_mathsyntaxhelp {{/str}}</th>
                <th scope="col" class="border-top-0">{{#str}} input_syntax, block_mathsyntaxhelp {{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#entries}}
                <tr>
                    <td>
                        <input
                            type="text"
                            id="{{name}}_{{id}}_out"
                            name="{{name}}[{{id}}][out]"
                            value="{{out}}"
                            size="32"
                            class="form-control"
                        />
                    </td>
                    <td>
                        <input
                            type="text"
                            id="{{name}}_{{id}}_in"
                            name="{{name}}[{{id}}][in]"
                            value="{{in}}"
                            size="32"
                            class="form-control"
                        />
                    </td>
                </tr>
            {{/entries}}
        </tbody>
    </table>
</div>
