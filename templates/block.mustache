{{!
    @template block_mathsyntaxhelp/block

    Displays the a block instance.

    Example context (json):
    {
        "content": [
            {
                "mathjax": "\\(\\log_e(y)\\): \)",
                "syntax": "ln(y)"
            },
            {
                "mathjax": "\\(\\sqrt{x}\\)",
                "syntax": "sqrt(x)"
            }
        ]
    }
}}

<table>
    {{#content}}
        <tr>
            <td>{{{mathjax}}}</td>
            <td>{{{syntax}}}</td>
        </tr>
    {{/content}}
</table>
